# ===== Discord Bot VIE — cấu hình môi trường =====
# Copy file này thành .env rồi điền giá trị thật:
#   Windows:  copy .env.example .env
#   Mac/Linux: cp .env.example .env

# BẮT BUỘC — Token của bot
# Lấy tại: Developer Portal > chọn App > Bot > Reset Token
# ⚠️ TUYỆT ĐỐI KHÔNG chia sẻ / commit token này lên git.
DISCORD_TOKEN=your_bot_token_here

# BẮT BUỘC — Application (Client) ID
# Lấy tại: Developer Portal > General Information > Application ID
DISCORD_CLIENT_ID=your_application_id_here

# BẮT BUỘC (khuyến nghị) — Server (Guild) ID nơi chạy bot.
# Bot này thiết kế dùng riêng cho từng server, nên đăng ký lệnh theo GUILD
# để lệnh gạch chéo "/" hiện NGAY LẬP TỨC (đăng ký global phải chờ tới ~1 giờ).
# Cách lấy: Discord > Cài đặt > Nâng cao > bật Chế độ nhà phát triển,
#           rồi chuột phải lên tên server > Sao chép ID máy chủ.
# Sau khi điền, chạy:  npm run register
# (Muốn dùng chung cho MỌI server thì để trống và chạy: npm run register:global)
DISCORD_GUILD_ID=your_server_id_here

# User ID admin dùng được lệnh quản trị (/add, /remove, /resetmoney, v!name, v!legit).
# Nhiều admin thì ngăn cách bằng dấu phẩy: 123456,789012
# Cách lấy: bật Chế độ nhà phát triển > chuột phải avatar của bạn > Sao chép ID người dùng.
ADMIN_IDS=your_discord_user_id

# Tiền tố lệnh dạng chữ (mặc định: v). Ví dụ: v work, v hunt
PREFIX=v
